# ─── MTG Genetic League — Environment Configuration ──────────────────────────
# This file contains sensitive credentials and deployment-specific settings.
# NEVER commit this file to version control.
# Copy .env.example to .env and fill in production values.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mtg_league
DATABASE_URL=postgresql://postgres:postgres@db:5432/mtg_league

# Redis
REDIS_URL=redis://redis:6379

# Milvus (vector DB for card similarity)
MILVUS_PATH=http://milvus-standalone:19530

# MinIO (object storage for Milvus)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Application
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# CORS (set to your frontend origin in production)
CORS_ORIGIN=http://localhost:3000
